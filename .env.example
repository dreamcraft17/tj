# Trusted Jurist — salin ke .env.local dan isi nilai asli
# cp .env.example .env.local

# ─── Email (Resend — direkomendasikan) ───
# https://resend.com → API Keys → verifikasi domain trustedjurist.co.id
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Trusted Jurist <noreply@trustedjurist.co.id>
ADMIN_EMAIL=konsultasi@trustedjurist.co.id

# ─── reCAPTCHA v3 (opsional di dev, wajib di production) ───
# https://www.google.com/recaptcha/admin/create
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── Rate limiting opsional (Upstash Redis, multi-instance) ───
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
